# ── Database ──────────────────────────────────────────────────────────────────
# Dev (SQLite, no setup required):
DATABASE_URL=sqlite:///./dev.db

# Prod (PostgreSQL — set POSTGRES_PASSWORD and uncomment):
# DATABASE_URL=postgresql://glancefive:changeme@db:5432/glancefive
POSTGRES_PASSWORD=changeme-strong-password-here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-hex-secret

# AES-256-GCM key for Amazon credentials (32 bytes, base64-encoded)
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=replace-with-base64-32-byte-key

# JWT settings (defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://redis:6379/2

# ── Celery Flower (monitoring UI) ─────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=replace-with-strong-password

# ── Amazon Advertising API ────────────────────────────────────────────────────
# These are set per-client via the Settings UI, not globally here.
# The API URLs below are the defaults — only change for non-EU marketplace.
AMAZON_TOKEN_URL=https://api.amazon.com/auth/o2/token
AMAZON_PROFILES_URL=https://advertising-api-eu.amazon.com/v2/profiles
AMAZON_REPORTS_URL=https://advertising-api-eu.amazon.com/reporting/reports
