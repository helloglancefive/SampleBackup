# Auto-detect line endings
* text=auto

# Force Unix line endings for Python and JS/TS files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env.example text eol=lf

# Binary files
*.db binary
*.png binary
*.jpg binary
*.gz binary
