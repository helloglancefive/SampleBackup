# Database
DATABASE_URL=sqlite:///./dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/amazon_ads_platform

# Security — generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# Encryption key for Amazon credentials — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_generate_with_fernet

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# Phase 2+ (leave empty for Phase 1)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP) — password reset delivery
# Leave SMTP_HOST empty to disable (logs a warning instead of sending)
# Gmail example: host=smtp.gmail.com, port=587, use_tls=true, user=you@gmail.com, password=app-password
# Mailgun: host=smtp.mailgun.org, port=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@glancefive.com
SMTP_USE_TLS=true

# Amazon Advertising API (Phase 2) — per-client credentials stored encrypted in DB
# These URL defaults work for EU region; change for NA: advertising-api.amazon.com
AMAZON_TOKEN_URL=https://api.amazon.com/auth/o2/token
AMAZON_PROFILES_URL=https://advertising-api-eu.amazon.com/v2/profiles
AMAZON_REPORTS_URL=https://advertising-api-eu.amazon.com/reporting/reports

# Amazon SP-API (Phase 3) — Business Reports integration
# Per-client SP credentials (sp_refresh_token, sp_marketplace_id, amazon_region)
# are stored encrypted in client_amazon_credentials table.
# The region per client is stored in amazon_region column (NA | EU | FE).
SP_API_BASE_URL_NA=https://sellingpartnerapi-na.amazon.com
SP_API_BASE_URL_EU=https://sellingpartnerapi-eu.amazon.com
SP_API_BASE_URL_FE=https://sellingpartnerapi-fe.amazon.com
