# Set this in Netlify → Site settings → Environment variables
# NOT as a file in git (the URL is not secret but changes when tunnel changes)
#
# Your backend tunnel URL — no trailing slash
# ngrok example:      https://glancefive.ngrok-free.app
# Cloudflare example: https://api.yourdomain.com
VITE_API_URL=https://YOUR-TUNNEL-URL.ngrok-free.app
